rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Break recursion: Check if user is reading their OWN doc first.
      // This allows isAdmin() to call get() on the current user's doc safely.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Navigation Collection ---
    match /navigation/{navId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Resource Links Collection ---
    match /resource_links/{linkId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Internal Notes ---
    match /notes/{noteId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.isShared == true || 
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
      allow update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }

    // --- Directus Guides Collection ---
    match /directus_guides/{guideId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Usage Logs ---
    match /usage/{usageId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }
    
    // --- Tool Ideas ---
    match /tool_ideas/{ideaId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid &&
         request.resource.data.status == resource.data.status)
      );
    }

    // --- AI Subscriptions Tracker ---
    match /subscriptions/{subId} {
      allow read, write: if isAdmin();
    }

    // --- Tool Configurations (Rules) ---
    match /configurations/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Changelog History ---
    match /changelog/{logId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Legacy Feedback ---
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }

    // --- Tool Config (unified configuration layer) ---
    match /tool_config/{toolId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Unified Tool Reports ---
    match /tool_reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }

    // --- Thematic QA Reports ---
    match /tqa_reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // --- QA Runs (immutable — no update/delete allowed) ---
    match /qa_runs/{runId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.triggered_by_user_id == request.auth.uid || isAdmin()
      );
      allow update, delete: if false;
    }

    // --- QA Prompt Versions (admin-only write, all auth users can read active prompts) ---
    match /qa_versions/{versionId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- AI Tool Settings (capability tier overrides, admin write, all authenticated users read) ---
    match /tool_settings/{toolId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // =========================================================================
    // QA Engine v1 Collections
    // =========================================================================

    // --- QA Lessons ---
    // Writers can create and update NON-stage fields on their own lessons.
    // Stage status fields for ALL 5 stages, their timestamps, and logging fields
    // are write-protected for writers — only the service layer may update them.
    match /qa_lessons/{lessonId} {
      allow read: if request.auth != null && (
        resource.data.writer_id == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.writer_id == request.auth.uid &&
        request.resource.data.qa_version == 'v1';
      // Writers may update title/content fields, but CANNOT touch any governed field
      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.writer_id == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          // Stage status fields (all 5 stages)
          'stage1_status', 'stage2_status', 'stage3_status',
          'stage4_status', 'stage5_status',
          // Final status fields
          'final_academic_status', 'final_production_status',
          // Gate reason
          'blocked_reason',
          // Audit timestamps (all 5 stages × 2)
          'stage1_started_at', 'stage1_cleared_at',
          'stage2_started_at', 'stage2_cleared_at',
          'stage3_started_at', 'stage3_cleared_at',
          'stage4_started_at', 'stage4_cleared_at',
          'stage5_started_at', 'stage5_cleared_at',
          // Execution status fields (Stage 3 and 4)
          'stage3_execution_status', 'stage4_execution_status',
          // Phase 2C structured logging fields
          'proofreading_correction_count', 'proofreading_density',
          'design_correction_count'
        ])
      );
      allow delete: if false;
    }


    // --- QA Runs v1 (strictly immutable) ---
    // No update or delete is permitted — enforced here, not by convention.
    match /qa_runs_v1/{runId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/qa_lessons/$(resource.data.lesson_id)).data.writer_id
          == request.auth.uid
      );
      allow update, delete: if false;
    }

    // --- QA Modules (admin-only write, no deletion) ---
    match /qa_modules/{moduleId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if false; // deactivate only — history must be preserved
    }

    // --- QA Config v1 (versioned thresholds — admin-only, no deletion) ---
    // Thresholds are never hardcoded. Every run captures threshold_version.
    match /qa_config_v1/{configId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // --- QA Disagreements ---
    // Writer creates. Admin resolves. Immutable once resolved_at is set.
    match /qa_disagreements/{disagreementId} {
      allow create: if request.auth != null &&
        request.resource.data.writer_id == request.auth.uid &&
        request.resource.data.requires_escalation == true;
      allow read: if request.auth != null && (
        resource.data.writer_id == request.auth.uid || isAdmin()
      );
      // Admin can resolve only if not already resolved
      allow update: if isAdmin() && resource.data.resolved_at == null;
      allow delete: if false;
    }

    // --- QA Escalations (auto-created in batch with disagreements) ---
    match /qa_escalations/{escalationId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update: if isAdmin() && resource.data.status == 'pending';
      allow delete: if false;
    }

    // --- QA Overrides (admin create-only, fully immutable) ---
    match /qa_overrides/{overrideId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    // --- QA Snapshots (create-once after Stage 2 clears — strictly immutable) ---
    // Consumed by Stages 3 and 4. No re-creation after first snapshot per lesson.
    match /qa_snapshots/{snapshotId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/qa_lessons/$(resource.data.lesson_id)).data.writer_id
          == request.auth.uid
      );
      allow update, delete: if false;
    }

    // --- QA Proofreading Runs v1 (Stage 3 — strictly immutable) ---
    match /qa_proofreading_runs_v1/{runId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/qa_lessons/$(resource.data.lesson_id)).data.writer_id
          == request.auth.uid
      );
      allow update, delete: if false;
    }

    // --- QA Design Runs v1 (Stage 4 — strictly immutable) ---
    match /qa_design_runs_v1/{runId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/qa_lessons/$(resource.data.lesson_id)).data.writer_id
          == request.auth.uid
      );
      allow update, delete: if false;
    }
  }
}